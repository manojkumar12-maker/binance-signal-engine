# ============================================
# DATABASE (Railway PostgreSQL)
# ============================================
# Set by Railway automatically when you add PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================
# REDIS CACHE (Railway Redis)
# ============================================
# Set by Railway automatically when you add Redis plugin
REDIS_URL=redis://default:password@host:6379

# ============================================
# TELEGRAM NOTIFICATIONS
# ============================================
# Enable Telegram signals
TELEGRAM_ENABLED=false

# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get chat ID from @userinfobot or create a group
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# BINANCE (Optional - defaults work fine)
# ============================================
# BINANCE_WS_URL=wss://fstream.binance.com/ws
# BINANCE_API_URL=https://fapi.binance.com

# ============================================
# SERVER
# ============================================
# PORT is set automatically by Railway
# PORT=3000
