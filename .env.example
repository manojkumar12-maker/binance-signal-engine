# Database (SQLite - no changes needed for local development)
DATABASE_URL="file:./dev.db"

# Server Port
PORT=3000

# ============================================
# TELEGRAM NOTIFICATIONS (Required for signals)
# ============================================
# Set to true to enable Telegram notifications
TELEGRAM_ENABLED=false

# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get your chat ID from @userinfobot or create a group and use the group ID
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# DISCORD NOTIFICATIONS (Optional)
# ============================================
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# ============================================
# BINANCE CONNECTION (Optional - defaults work fine)
# ============================================
# BINANCE_WS_URL=wss://fstream.binance.com/ws
# BINANCE_API_URL=https://fapi.binance.com
